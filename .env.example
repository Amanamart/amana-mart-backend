# =============================================================================
# AmanaMart Backend — Environment Variables
# Copy this file to .env and fill in actual values
# =============================================================================

# -------------------------
# Core
# -------------------------
NODE_ENV=development
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------
# Database (Supabase)
# -------------------------
# Get from: https://supabase.com → Project → Settings → Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# -------------------------
# Auth
# -------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change_this_to_a_long_random_string
NEXTAUTH_URL=http://localhost:3000

# -------------------------
# Cloudflare R2 Storage
# -------------------------
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=amanamart
# Public URL (if R2 bucket has custom domain or public access)
R2_PUBLIC_URL=https://files.amanamart.com.bd

# -------------------------
# Meilisearch
# -------------------------
# Local: http://localhost:7700
# Cloud: https://your-instance.meilisearch.io
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=change_this_to_a_strong_master_key
MEILISEARCH_API_KEY=

# -------------------------
# Redis (Upstash recommended for managed)
# -------------------------
# Upstash: https://console.upstash.com → Redis → REST URL format
REDIS_URL=redis://:password@localhost:6379
# Or Upstash format:
# REDIS_URL=rediss://default:password@your-instance.upstash.io:6379

# -------------------------
# RabbitMQ (CloudAMQP recommended)
# -------------------------
# CloudAMQP: https://www.cloudamqp.com
RABBITMQ_URL=amqp://localhost:5672
# Or CloudAMQP format:
# RABBITMQ_URL=amqps://user:password@your-instance.cloudamqp.com/vhost

# -------------------------
# WhatsApp / Messaging
# -------------------------
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# -------------------------
# Monitoring
# -------------------------
SENTRY_DSN=

# -------------------------
# Maps
# -------------------------
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

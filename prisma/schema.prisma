}

model ClassifiedPromotionPackage {
  id           String   @id @default(cuid())
  name         String   // Top Ad, Urgent, Featured, Homepage Featured
  slug         String   @unique
  type         String   // top_ad, urgent, featured, homepage_featured, category_featured
  description  String?
  price        Float
  durationDays Int      @default(7)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  promotions   ClassifiedAdPromotion[]

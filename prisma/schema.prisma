// -----------------------------------------------------------------------------
// Search & Indexing Models
// -----------------------------------------------------------------------------

model SearchLog {
  id          String   @id @default(cuid())
  userId      String?
  query       String
  module      String?
  zoneId      String?
  resultCount Int      @default(0)
  mode        String   @default("meilisearch") // meilisearch, fallback_postgres
  processingTimeMs Int?
  createdAt   DateTime @default(now())
}

model PopularSearchTerm {
  id            String   @id @default(cuid())
  term          String
  module        String?
  count         Int      @default(1)
  lastSearchedAt DateTime @default(now())

  @@unique([term, module])
}

model NoResultSearch {
  id        String   @id @default(cuid())
  query     String
  module    String?
  zoneId    String?
  createdAt DateTime @default(now())
}

model SearchIndexJob {
  id           String   @id @default(cuid())
  entityType   String   // product, category, store, classified_ad, etc.
  entityId     String
  action       String   // create, update, delete

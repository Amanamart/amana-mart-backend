// -----------------------------------------------------------------------------
// Super App Modules: Ride-Sharing & Rental (Uber/Turo-like)
// -----------------------------------------------------------------------------

model Vehicle {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // BIKE, CAR, CAR_XL, TRUCK, VAN
  brand           String?
  model           String?
  year            Int?
  plateNumber     String   @unique
  color           String?
  image           String?
  status          String   @default("active") // active, inactive, maintenance
  
  // Rental specific
  isForRental     Boolean  @default(false)
  isForRideShare  Boolean  @default(true)
  hourlyRate      Float?
  dailyRate       Float?
  monthlyRate     Float?
  depositAmount   Float?
  availability    Json?    // Calendar availability
  
  rides           RideRequest[]
  rentalBookings  RentalBooking[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RideRequest {
  id              String   @id @default(cuid())
  customerId      String
  customer        User     @relation("RideCustomer", fields: [customerId], references: [id])
  driverId        String?
  driver          User?    @relation("RideDriver", fields: [driverId], references: [id])
  vehicleId       String?
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  
  pickupAddress   String   @db.Text
  pickupLat       Float
  pickupLng       Float
  
  dropoffAddress  String   @db.Text
  dropoffLat      Float
  dropoffLng      Float
  
  distance        Float?   // in km
  duration        Float?   // in minutes
  fare            Float
  status          String   @default("pending") // pending, accepted, ongoing, completed, cancelled
  paymentStatus   String   @default("unpaid")
  paymentMethod   String   @default("cash")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerId])
  @@index([driverId])
  @@index([status])
}

model RentalBooking {
  id              String   @id @default(cuid())
  customerId      String
  customer        User     @relation("RentalCustomer", fields: [customerId], references: [id])
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  
  startDate       DateTime
  endDate         DateTime
  pickupLocation  String?
  dropoffLocation String?
  
  totalFare       Float
  depositAmount   Float
  status          String   @default("pending") // pending, confirmed, active, completed, cancelled, overdue
  paymentStatus   String   @default("unpaid")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerId])
  @@index([vehicleId])
}

// -----------------------------------------------------------------------------
// Super App Modules: Home Services (Sheba-like)

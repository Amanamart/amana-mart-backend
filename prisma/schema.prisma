  @@index([customerId])
  @@index([providerId])
}

// -----------------------------------------------------------------------------
// Super App Modules: Parcel Delivery
// -----------------------------------------------------------------------------

model ParcelOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  customer        User     @relation("ParcelCustomer", fields: [customerId], references: [id])
  riderId         String?
  rider           User?    @relation("ParcelRider", fields: [riderId], references: [id])
  
  pickupAddress   String   @db.Text
  pickupPhone     String
  pickupName      String
  
  dropoffAddress  String   @db.Text
  dropoffPhone    String
  dropoffName     String
  
  packageType     String   // document, fragile, electronics, etc.
  weight          Float?   // in kg
  distance        Float?   // in km
  fare            Float
  
  status          String   @default("pending") // pending, picked_up, in_transit, delivered, cancelled
  paymentStatus   String   @default("unpaid")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerId])
  @@index([riderId])
}

// -----------------------------------------------------------------------------
// Affiliate System
// -----------------------------------------------------------------------------

model AffiliateProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  referralCode    String   @unique
  status          String   @default("pending") // pending, active, suspended
  totalEarnings   Float    @default(0)
  paidEarnings    Float    @default(0)
  
  links           AffiliateLink[]
  clicks          AffiliateClick[]
  commissions     AffiliateCommission[]
  payouts         AffiliatePayout[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AffiliateLink {
  id              String   @id @default(cuid())
  affiliateId     String
  affiliate       AffiliateProfile @relation(fields: [affiliateId], references: [id])
  targetUrl       String
  slug            String   @unique
  clickCount      Int      @default(0)
  createdAt       DateTime @default(now())
}

model AffiliateClick {
  id              String   @id @default(cuid())
  affiliateId     String
  affiliate       AffiliateProfile @relation(fields: [affiliateId], references: [id])
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
}

model AffiliateCommission {
  id              String   @id @default(cuid())
  affiliateId     String
  affiliate       AffiliateProfile @relation(fields: [affiliateId], references: [id])
  orderId         String?
  amount          Float
  status          String   @default("pending") // pending, approved, rejected, paid
  createdAt       DateTime @default(now())
}

model AffiliatePayout {
  id              String   @id @default(cuid())
  affiliateId     String
  affiliate       AffiliateProfile @relation(fields: [affiliateId], references: [id])
  amount          Float
  method          String
  status          String   @default("pending") // pending, completed, rejected
  createdAt       DateTime @default(now())
}

